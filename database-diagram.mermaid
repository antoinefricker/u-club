erDiagram
    USER {
        uuid id PK
        string display_name
        text bio
        string phone
        string email UK
        string password
        timestamp created_at
        timestamp updated_at
    }

    LOGIN_TOKEN {
        uuid id PK
        string email
        string token UK
        timestamp expires_at
        timestamp created_at
    }

    REVOKED_TOKEN {
        uuid id PK
        text token UK
        timestamp expires_at
        timestamp created_at
    }

    %% ── Relationships ────────────────────────────────────

    USER          ||--o{ LOGIN_TOKEN        : "requests"
    USER          ||--o{ REVOKED_TOKEN      : "revokes"
