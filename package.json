{
  "name": "u-club",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @u-club/api dev",
    "dev:pwa": "pnpm --filter @u-club/pwa dev",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
