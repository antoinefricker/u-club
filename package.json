{
  "name": "eggplant",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @eggplant/api dev",
    "dev:pwa": "pnpm --filter @eggplant/pwa dev",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @eggplant/e2e test",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "apps/pwa/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.8.0"
}
