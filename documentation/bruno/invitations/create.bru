meta {
  name: Send Invitation
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/invitations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "member_id": "paste-member-id-here",
    "email": "invitee@example.com",
    "type": "relative",
    "description": "mother"
  }
}
