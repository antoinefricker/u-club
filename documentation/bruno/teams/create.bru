meta {
  name: Create Team
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/teams
  body: json
  auth: bearer
}

body:json {
  {
    "club_id": "paste-club-id-here",
    "label": "U15 Boys",
    "year": 2026,
    "gender": "male",
    "description": "Under 15 boys team"
  }
}

auth:bearer {
  token: {{accessToken}}
}
