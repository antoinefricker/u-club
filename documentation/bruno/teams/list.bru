meta {
  name: List Teams
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/teams
  body: none
  auth: bearer
}

params:query {
  ~clubId:
  ~gender:
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Optional query parameters:
  - clubId: UUID — filter by club
  - gender: male | female | mixed — filter by gender (400 if invalid)
}
