{
    "singleQuote": true,
    "trailingComma": "all",
    "semi": true,
    "tabWidth": 4,
    "printWidth": 120,
    "endOfLine": "lf",
    "arrowParens": "always",
    "overrides": [
        {
            "files": "*.md",
            "options": { "tabWidth": 2, "proseWrap": "preserve" }
        }
    ]
}
